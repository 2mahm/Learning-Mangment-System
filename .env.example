# ── Django ────────────────────────────────────────────────────────────────────
# Generate a real one with: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=your-secret-key-here

DEBUG=True

# Comma-separated — use * to allow all (dev only)
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost:3000,https://yourdomain.com

# ── Database ──────────────────────────────────────────────────────────────────
# Leave DB_HOST empty to fall back to SQLite (local dev without Docker)
DB_HOST=db
DB_NAME=lms
DB_USER=lms
DB_PASSWORD=lms_secret
DB_PORT=5432

# ── Bitly URL shortener ───────────────────────────────────────────────────────
# Get your token at: https://app.bitly.com/settings/api
# Note: Bitly does not shorten localhost URLs — use a real domain in production
BITLY_TOKEN=your-bitly-token-here
SITE_BASE_URL=https://yourdomain.com

# ── Email (Gmail SMTP) ────────────────────────────────────────────────────────
# Use a Gmail App Password — NOT your real Gmail password.
# Enable it at: https://myaccount.google.com/apppasswords
EMAIL_HOST_USER=your-gmail@gmail.com
EMAIL_HOST_PASSWORD=your-app-password-here

# ── Frontend (Vite) ───────────────────────────────────────────────────────────
# Docker: use the backend service name
# Local dev: use http://localhost:8000
VITE_BACKEND_URL=http://backend:8000
